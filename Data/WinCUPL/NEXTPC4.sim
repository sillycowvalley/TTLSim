%SIGNAL
PIN   8 =  C 
PIN  22 =  LD_PC 
PIN   6 =  N 
PIN   2 =  OP0 
PIN   3 =  OP1 
PIN   4 =  OP2 
PIN   5 =  OP3 
PIN   7 =  Z 
%END

%FIELD
%END

%EQUATION
LD_PC =>
    OP0 & OP1 & OP2 & !OP3
